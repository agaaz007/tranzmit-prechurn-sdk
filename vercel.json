{
  "version": 2,
  "installCommand": "pnpm install --frozen-lockfile --prod=false",
  "buildCommand": "pnpm build && mkdir -p public && echo '{}' > public/index.json",
  "outputDirectory": "public",
  "functions": {
    "api/index.js": {
      "includeFiles": "packages/embed/dist/**|packages/widget/dist/**"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ]
}
